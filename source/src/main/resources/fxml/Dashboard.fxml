<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.studentmgmt.ui.controllers.DashboardController">
    <VBox spacing="24" styleClass="screen-container">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

        <Label text="Dashboard" styleClass="screen-title"/>

        <!-- Stats row -->
        <HBox spacing="16">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Total Students" styleClass="stat-label"/>
                <Label fx:id="lblTotal" text="0" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Active" styleClass="stat-label"/>
                <Label fx:id="lblActive" text="0" styleClass="stat-value stat-green"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Inactive" styleClass="stat-label"/>
                <Label fx:id="lblInactive" text="0" styleClass="stat-value stat-red"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="Average GPA" styleClass="stat-label"/>
                <Label fx:id="lblAvgGpa" text="0.00" styleClass="stat-value stat-blue"/>
            </VBox>
        </HBox>

        <!-- Quick actions -->
        <VBox spacing="12">
            <Label text="Quick Actions" styleClass="section-title"/>
            <HBox spacing="12">
                <Button text="🎓 Manage Students" styleClass="action-btn" onAction="#goStudents" prefWidth="180"/>
                <Button text="📊 View Reports"    styleClass="action-btn" onAction="#goReports"  prefWidth="180"/>
                <Button text="📥 Import Records"  styleClass="action-btn" onAction="#goImport"   prefWidth="180"/>
                <Button text="📤 Export Data"     styleClass="action-btn" onAction="#goExport"   prefWidth="180"/>
                <Button text="⚙ Settings"         styleClass="action-btn" onAction="#goSettings" prefWidth="180"/>
            </HBox>
        </VBox>

        <!-- Recent students placeholder -->
        <VBox spacing="8">
            <Label text="Recent Students" styleClass="section-title"/>
            <TableView fx:id="recentTable" prefHeight="220">
                <columns>
                    <TableColumn fx:id="colId"   text="ID"        prefWidth="120"/>
                    <TableColumn fx:id="colName" text="Full Name" prefWidth="200"/>
                    <TableColumn fx:id="colProg" text="Programme" prefWidth="200"/>
                    <TableColumn fx:id="colGpa"  text="GPA"       prefWidth="80"/>
                    <TableColumn fx:id="colStat" text="Status"    prefWidth="90"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
